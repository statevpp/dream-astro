# Копирай на .env.local за локална разработка, или сложи същите имена
# в Vercel Project Settings -> Environment Variables за деплой.
# НИКОГА не commit-вай истински ключове в git — само този example файл.

# --- Astrology data API (AstrologyAPI.com или Prokerala) ---
ASTROLOGY_API_BASE_URL=https://json.astrologyapi.com/v1
ASTROLOGY_API_USER_ID=
ASTROLOGY_API_KEY=

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Postgres (Vercel Postgres или Supabase connection string) ---
POSTGRES_URL=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_DREAM=
STRIPE_PRICE_HOROSCOPE=
STRIPE_PRICE_NATAL=
STRIPE_PRICE_COMPAT=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_SUBSCRIPTION=            # recurring, 5.99 €/мес, 30-дневен trial
STRIPE_PRICE_SUBSCRIPTION_ANNUAL=     # recurring, 49 €/год (~32% отстъпка спрямо месечния x12)

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM="Astral Guide <hello@astral-guide.com>"

# --- Auth (magic-link JWT) ---
AUTH_SECRET=

# --- Cron protection ---
CRON_SECRET=

# --- Misc ---
SITE_URL=https://astral-guide.com
